{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:databases": "cross-env DOCKER_API_VERSION=1.45 docker compose up -d",
    "dev:frontend": "next dev FRONTEND --webpack",
    "dev:backend-order": "cd order-cart-service && mvnw.cmd spring-boot:run",
    "dev:backend-payment": "cd payment-notification-service && mvnw.cmd spring-boot:run",
    "dev:backend-auth": "cd auth-user-service && mvnw.cmd spring-boot:run",
    "dev:backend-inventory": "node scripts/run-inventory.js",
    "dev": "npm run dev:databases && concurrently --kill-others-on-fail \"npm run dev:frontend\" \"npm run dev:backend-order\" \"npm run dev:backend-payment\" \"npm run dev:backend-auth\" \"npm run dev:backend-inventory\"",
    "build": "next build FRONTEND",
    "start": "next start FRONTEND",
    "lint": "eslint FRONTEND"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "swiper": "^14.0.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
